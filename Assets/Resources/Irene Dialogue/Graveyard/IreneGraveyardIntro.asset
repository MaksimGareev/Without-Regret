  m_Name: IreneGraveyardIntro
  m_EditorClassIdentifier: Assembly-CSharp::NewDialogueData
  npcName: Irene
  dialogueLines:
  - LineID: Start
    Speaker: Irene
    text: Hey Echo! Slept well, huh? You didn't even fix your hair!
    lineTone: 0
    NPCGender: female
    NextLineID: Go To Graveyard
    endDialogueAfterLine: 0
    choices: []
    objectivesToActivate: []
  - LineID: Go To Graveyard
    Speaker: Irene
    text: So, we still going to the Graveyard?
    lineTone: 0
    NPCGender: female
    NextLineID: Question
    endDialogueAfterLine: 0
    choices: []
    objectivesToActivate: []
  - LineID: Question
    Speaker: Irene
    text: You should respond with how you truly feel, just remember that your choices
      affect the world around you.
    lineTone: 0
    NPCGender: female
    NextLineID: 
    endDialogueAfterLine: 0
    choices:
    - text: Of course.
      NextLineID: 
      moralityChange: 0
      direction: 0
      objectiveToActivate: 
    - text: Meh.
      NextLineID: Bad
      moralityChange: -1
      direction: 1
      objectiveToActivate: 
    - text: I'm a bit tired, but we're going no matter what.
      NextLineID: Good
      moralityChange: 1
      direction: 2
      objectiveToActivate: 
    - text: Let me snooze for five more minutes...
      NextLineID: Bad
      moralityChange: -1
      direction: 3
      objectiveToActivate: 
    objectivesToActivate: []
  - LineID: Good
    Speaker: Irene
    text: Yay!  Let's go.
    lineTone: 0
    NPCGender: female
    NextLineID: 
    endDialogueAfterLine: 1
    choices: []
    objectivesToActivate: []
  - LineID: Bad
    Speaker: Irene
    text: Ouch...well, I already walked over so we're going anyways.
    lineTone: 0
    NPCGender: female
    NextLineID: 
    endDialogueAfterLine: 1
    choices: []
    objectivesToActivate: []
