  - LineID: Good
    Speaker: Irene
    text: Of course you did. Sorry for doubting you.
    lineTone: 1
    NPCGender: female
    NextLineID: Good II
    endDialogueAfterLine: 0
    choices: []
    objectivesToActivate: []
  - LineID: Good II
    Speaker: Irene
    text: Those are beautiful! Great job, Echo.
    lineTone: 1
    NPCGender: female
    NextLineID: Check On Reed
    endDialogueAfterLine: 0
    choices: []
    objectivesToActivate: []
  - LineID: Bad
