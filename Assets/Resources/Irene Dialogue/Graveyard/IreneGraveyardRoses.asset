    text: Seriously?!?!
    lineTone: 2
    NPCGender: female
    NextLineID: Bad II
    endDialogueAfterLine: 0
    choices: []
    objectivesToActivate: []
  - LineID: Bad II
    Speaker: Irene
    text: Ugh, I can't believe you Echo.
    lineTone: 2
    NPCGender: female
    NextLineID: Check On Reed
    endDialogueAfterLine: 0
    choices: []
    objectivesToActivate: []
  - LineID: Check On Reed
