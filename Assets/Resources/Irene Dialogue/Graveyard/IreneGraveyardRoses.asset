  npcName: Irene
  dialogueLines:
  - LineID: Start
    Speaker: Irene
    text: Oh, I almost forgot! Did you bring the flowers?
    lineTone: 0
    NPCGender: female
    NextLineID: 
    endDialogueAfterLine: 0
