{
    "dialogueLines": [
        {
            "LineID": "start",
            "Speaker": "Irene",
            "NPCGender": "female",
            "text": "You give flowers to our friends yet?",
            "lineTone": 0,
            "requiredMorality": 0,
            "choices": [
                {
                    "text": "(Nod)",
                    "moralityChange": 1,
                    "directionString": "Up",
                    "NextLineID": "Good response"
                },
                {
                    "text": "(Shake head)",
                    "moralityChange": -1,
                    "directionString": "Down",
                    "NextLineID": "Bad response"
                }
            ]
        },
        {
            "LineID": "Good response",
            "Speaker": "Irene",
            "NPCGender": "female",
            "text": "Good. I know they appreciate them.",
            "lineTone": 0,
            "requiredMorality": 1,
            "NextLineID": "Story start",
            "choices": []
        },
        {
            "LineID": "Bad response",
            "Speaker": "Irene",
            "NPCGender": "female",
            "text": "So you just got them for yourself? What's up with you?",
            "lineTone": 0,
            "requiredMorality": -1,
            "NextLineID": "Story start",
            "choices": []
        },
        {
            "LineID": "Story start",
            "Speaker": "Irene",
            "NPCGender": "female",
            "text": "Oh! I almost forgot. Here, I found this in front of your door.",
            "lineTone": 0,
            "requiredMorality": 0,
            "NextLineID": "Story 2",
            "choices": []
        },
        {
            "LineID": "Story 2",
            "Speaker": "Irene",
            "NPCGender": "female",
            "text": "...I'm sorry, I was trying to not bring it up, but I still can't believe Penelope's gone.",
            "lineTone": 0,
            "requiredMorality": 0,
            "NextLineID": "Story 3",
            "choices": []
        },
        {
            "LineID": "Story 3",
            "Speaker": "Irene",
            "NPCGender": "female",
            "text": "I tried warning her about going out that night. She didn't listen, but I still can't help but feel that it's my fault.",
            "lineTone": 0,
            "requiredMorality": 0,
            "choices": [
                {
                    "text": "You can't blame yourself.",
                    "moralityChange": 1,
                    "directionString": "Up",
                    "NextLineID": "Good response 1"
                },
                {
                    "text": "That's the last thing she'd think.",
                    "nextIndex": 6,
                    "moralityChange": 1,
                    "directionString": "Right",
                    "NextLineID": "Good response 1b"
                },
                {
                    "text": "Why didn't you go?",
                    "moralityChange": -1,
                    "directionString": "Down",
                    "NextLineID": "Bad response 1"
                },
                {
                    "text": "That's stupid, how's it your fault?",
                    "nextIndex": 7,
                    "moralityChange": -1,
                    "directionString": "Left",
                    "NextLineID": "Bad response 1b"
                }
            ]
        },
        {
            "LineID": "Good response 1",
            "Speaker": "Echo",
            "NPCGender": "female",
            "text": "Irene...you can't blame yourself for what happened.",
            "lineTone": 0,
            "requiredMorality": 1,
            "NextLineID": "Good response 2",
            "choices": []
        },
        {
            "LineID": "Good response 1b",
            "Speaker": "Echo",
            "NPCGender": "female",
            "text": "The LAST thing Penelope would think is that it was your fault, Irene. When she was set on something, she was set.",
            "lineTone": 0,
            "requiredMorality": 1,
            "NextLineID": "Good response 2",
            "choices": []
        },
        {
            "LineID": "Bad response 1",
            "Speaker": "Echo",
            "NPCGender": "female",
            "text": "If you were so worried, why didn't you go, Irene?",
            "lineTone": 0,
            "requiredMorality": 1,
            "NextLineID": "Bad response 2",
            "choices": []
        },
        {
            "LineID": "Bad response 1b",
            "Speaker": "Echo",
            "NPCGender": "female",
            "text": "Irene, that's stupid. Think about it, how could it have possibly been your fault?",
            "lineTone": 0,
            "requiredMorality": 1,
            "NextLineID": "Bad response 2",
            "choices": []
        },
        {
            "LineID": "Good response 2",
            "Speaker": "Irene",
            "NPCGender": "female",
            "text": "I know, I know. It's just hard...but thanks, Echo.",
            "lineTone": 0,
            "requiredMorality": 1,
            "NextLineID": "Story 4",
            "choices": []
        },
        {
            "LineID": "Bad response 2",
            "Speaker": "Irene",
            "NPCGender": "female",
            "text": "I ask myself that every day, Echo. If you hate being here with me so much, why'd you even come?",
            "lineTone": 0,
            "requiredMorality": -1,
            "NextLineID": "Story 4",
            "choices": []
        },
        {
            "LineID": "Story 4",
            "Speaker": "Irene",
            "NPCGender": "female",
            "text": "Sorry. It's just that...I would do anything to change what happened.",
            "lineTone": 0,
            "requiredMorality": 0,
            "NextLineID": "Story 5",
            "choices": []
        },
        {
            "LineID": "Story 5",
            "Speaker": "Irene",
            "NPCGender": "female",
            "text": "Oh man, it's getting late. I've gotta head back. I told Stevie I'd fix the gravestones that are tilting, would you be a doll and do it for me?.",
            "lineTone": 0,
            "requiredMorality": 0,
            "NextLineID": "Story 6",
            "choices": []
        },
        {
            "LineID": "Story 6",
            "Speaker": "Irene",
            "NPCGender": "female",
            "text": "Also, Stevie said he has something to give you, so go see him after you're done here.",
            "lineTone": 0,
            "requiredMorality": 0,
            "NextLineID": "end",
            "choices": []
        },
        {
            "LineID": "end",
            "Speaker": "Irene",
            "NPCGender": "female",
            "text": "Thanks for coming, Echo. See you tomorrow.",
            "lineTone": 0,
            "requiredMorality": 0,
            "choices": [],
            "objectiveToActivate": "talkToStevey",
            "endDialogueAfterLine": true
        }
    ]
}