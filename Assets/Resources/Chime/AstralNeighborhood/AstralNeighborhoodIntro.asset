  npcName: Chime
  dialogueLines:
  - LineID: Start
    Speaker: Chime
    text: Here in the Astral Plane, we are invisible to the others, but you have
      abilities, such as being able to subconsciously mediate in everyone's affairs
      and manipulate objects in the environment.
    lineTone: 0
    NPCGender: 
    NextLineID: Part II
    endDialogueAfterLine: 0
    choices: []
    objectivesToActivate: []
  - LineID: Part II
    Speaker: Chime
    text: Listen in on some of the conversations between people in the neighborhood.
      You'll be able to sway their thoughts and responses in conversation.
    lineTone: 0
    NPCGender: 
    NextLineID: Part II
    endDialogueAfterLine: 1
    choices: []
    objectivesToActivate: []
