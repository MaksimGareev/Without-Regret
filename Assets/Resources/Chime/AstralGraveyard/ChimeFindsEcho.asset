    NPCGender: female
    NextLineID: VIII
    endDialogueAfterLine: 0
    choices: []
    objectivesToActivate: []
  - LineID: VIII
    Speaker: Echo
    text: CHIME. YOU'RE CHIME! HOW COULD I FORGET?!
