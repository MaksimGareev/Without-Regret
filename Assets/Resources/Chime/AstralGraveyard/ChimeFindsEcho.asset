    NPCGender: female
    NextLineID: X
    endDialogueAfterLine: 0
    choices: []
    objectivesToActivate: []
  - LineID: X
    Speaker: Echo
    text: IT SHOULD HAVE BEEN ME. IT SHOULD HAVE BEEN ME! GET AWAY!!
    lineTone: 2
