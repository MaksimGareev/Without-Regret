%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 5e28c2e20bb6c4240a55d8edffb777ec, type: 3}
  m_Name: ChimeFinalPositive
  m_EditorClassIdentifier: Assembly-CSharp::NewDialogueData
  npcName: Echo
  dialogueLines:
  - LineID: Start
    Speaker: Chime
    text: Echo!
    lineTone: 0
    NPCGender: female
    NextLineID: II
    endDialogueAfterLine: 0
    choices: []
    objectivesToActivate: []
  - LineID: II
    Speaker: Echo
    text: Chime...is that you?
    lineTone: 0
    NPCGender: female
    NextLineID: III
    endDialogueAfterLine: 0
    choices: []
    objectivesToActivate: []
  - LineID: III
    Speaker: Chime
    text: Are you okay?! You were corrupted, I had to fight this awful version of
      you.
    lineTone: 0
    NPCGender: female
    NextLineID: IV
    endDialogueAfterLine: 0
    choices: []
    objectivesToActivate: []
  - LineID: IV
    Speaker: Echo
    text: I...couldn't control myself. Everything came back to me. This pendant,
      you gave it to me. It's the reason I'm here, right?
    lineTone: 0
    NPCGender: female
    NextLineID: V
    endDialogueAfterLine: 0
    choices: []
    objectivesToActivate: []
  - LineID: V
    Speaker: Chime
    text: ...It's one of the reasons, yes. I'm so sorry, Echo. I didn't want you
      to find out this way.
    lineTone: 0
    NPCGender: female
    NextLineID: VI
    endDialogueAfterLine: 0
    choices: []
    objectivesToActivate: []
  - LineID: VI
    Speaker: Echo
    text: No, I'm sorry...I should've died in the forest instead of you.
    lineTone: 0
    NPCGender: female
    NextLineID: VII
    endDialogueAfterLine: 0
    choices: []
    objectivesToActivate: []
  - LineID: VII
    Speaker: Chime
    text: Don't say that! How could say such an awful thing, Echo?
    lineTone: 2
    NPCGender: female
    NextLineID: VIII
    endDialogueAfterLine: 0
    choices: []
    objectivesToActivate: []
  - LineID: VIII
    Speaker: Echo
    text: You were the light of everyone's lives, Chime. I'm a fly on the wall. The
      world was a brighter place with you in it. I made no real difference.
    lineTone: 0
    NPCGender: female
    NextLineID: IX
    endDialogueAfterLine: 0
    choices: []
    objectivesToActivate: []
  - LineID: IX
    Speaker: Chime
    text: You made all the difference to me, Echo! I was only ever able to smile
      because you were keeping me from falling apart!
    lineTone: 0
    NPCGender: female
    NextLineID: X
    endDialogueAfterLine: 0
    choices: []
    objectivesToActivate: []
  - LineID: X
    Speaker: Echo
    text: Anyone could've been there for you...
    lineTone: 0
    NPCGender: female
    NextLineID: XI
    endDialogueAfterLine: 0
    choices: []
    objectivesToActivate: []
  - LineID: XI
    Speaker: Chime
    text: NOBODY was there for me like you were. Why do you think I gave you that
      pendant? You mean so much to me and many others, Echo. Please, try to see that...
    lineTone: 0
    NPCGender: female
    NextLineID: XII
    endDialogueAfterLine: 0
    choices: []
    objectivesToActivate: []
  - LineID: XII
    Speaker: Echo
    text: ...
    lineTone: 0
    NPCGender: female
    NextLineID: XIII
    endDialogueAfterLine: 0
    choices: []
    objectivesToActivate: []
  - LineID: XIII
    Speaker: Echo
    text: You're right. I'm so sorry, Chime. It took so much for me to see. Now that
      we're together again, can we go home?
    lineTone: 0
    NPCGender: female
    NextLineID: XIV
    endDialogueAfterLine: 0
    choices: []
    objectivesToActivate: []
  - LineID: XIV
    Speaker: Chime
    text: If you mean back to the original world, the one before the Astral Plane,
      I'm afraid we can't...
    lineTone: 0
    NPCGender: female
    NextLineID: XV
    endDialogueAfterLine: 0
    choices: []
    objectivesToActivate: []
  - LineID: XV
    Speaker: Chime
    text: We can, however, move on to the next one, together. Wherever it may be.
      Are you ready?
    lineTone: 1
    NPCGender: female
    NextLineID: 
    endDialogueAfterLine: 1
    choices: []
    objectivesToActivate: []
